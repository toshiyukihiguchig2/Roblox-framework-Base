{
  "name": "Roblox-framework-Base",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "FrameworkShared": {
        "$path": "src/framework/shared"
      },
      "obby": {
        "$className": "Folder",
        "Shared": {
          "$path": "src/games/obby/shared"
        }
      },
      "Packages": {
        "$path": "Packages"
      }
    },

    "ServerScriptService": {
      "FrameworkServer": {
        "$path": "src/framework/server"
      },
      "obby": {
        "$className": "Folder",
        "Server": {
          "$path": "src/games/obby/server"
        }
      },
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Framework": {
          "$path": "src/framework/client"
        },
        "obby": {
          "$className": "Folder",
          "Client": {
            "$path": "src/games/obby/client"
          }
        }
      }
    },

    "StarterGui": {
      "MainGui": {
        "$className": "ScreenGui",
        "$properties": {
          "ResetOnSpawn": false,
          "ZIndexBehavior": "Sibling"
        },
        "$path": "src/framework/ui"
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [0.38823, 0.37254, 0.38823],
          "Locked": true,
          "Position": [0, -10, 0],
          "Size": [512, 20, 512]
        }
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0, 0, 0],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "ShadowMap"
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
