{
  "name": "Roblox-framework-Base-Simulator",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "FrameworkShared": { "$path": "src/framework/shared" },
      "GameShared": { "$path": "src/games/simulator/shared" },
      "Packages": { "$path": "Packages" }
    },

    "ServerScriptService": {
      "Framework": { "$path": "src/framework/server" },
      "Game": { "$path": "src/games/simulator/server" },
      "ServerPackages": { "$path": "ServerPackages" }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Framework": { "$path": "src/framework/client" },
        "Game": { "$path": "src/games/simulator/client" }
      }
    },

    "StarterGui": {
      "MainGui": {
        "$className": "ScreenGui",
        "$properties": { "ResetOnSpawn": false, "ZIndexBehavior": "Sibling" },
        "$path": "src/framework/ui"
      }
    },

    "Workspace": {
      "$properties": { "FilteringEnabled": true },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [0.38823, 0.37254, 0.38823],
          "Locked": true,
          "Position": [0, -10, 0],
          "Size": [512, 20, 512]
        }
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0, 0, 0],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "ShadowMap"
      }
    },

    "SoundService": { "$properties": { "RespectFilteringEnabled": true } }
  }
}
